# ── Anvil — Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.

# LLM Provider (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# GitHub OAuth (required for web app mode)
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Session Security
SESSION_SECRET=change-me-to-a-random-32-byte-string
COOKIE_SECURE=false  # Set to true when using HTTPS in production

# Redis (required for Celery mode)
REDIS_URL=redis://localhost:6379/0

# SQLite (auto-created if missing)
SQLITE_DB_PATH=master_state.db

# Sandbox
SANDBOX_TIMEOUT_SECONDS=5
SANDBOX_MAX_RETRIES=3

# Omium / OpenTelemetry (optional)
OMIUM_API_KEY=
OMIUM_ENDPOINT=ingest.monium.yandex.cloud:443
SERVICE_NAME=red-team-engine

# LLM Tuning
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0

# Target Application (legacy mode only)
TARGET_APP_HOST=http://localhost:9999
TARGET_REPO_DIR=target_app
